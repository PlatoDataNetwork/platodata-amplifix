{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Vary",
          "value": "Accept-Language, Cookie"
        }
      ]
    }
  ],
  "rewrites": [
    { 
      "source": "/robots.txt", 
      "destination": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/robots-txt"
    },
    {
      "source": "/sitemap.xsl",
      "destination": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/sitemap-xsl"
    },
    { 
      "source": "/sitemap.xml", 
      "destination": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/sitemap?path=sitemap.xml"
    },
    { 
      "source": "/page-sitemap.xml", 
      "destination": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/sitemap?path=page-sitemap.xml"
    },
    { 
      "source": "/vertical-sitemap.xml", 
      "destination": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/sitemap?path=vertical-sitemap.xml"
    },
    { 
      "source": "/post-sitemap:num(\\d+).xml", 
      "destination": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/sitemap?path=post-sitemap:num.xml"
    },
    {
      "source": "/feed.xml",
      "destination": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/rss-feed"
    },
    {
      "source": "/feed.json",
      "destination": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/json-feed"
    },
    {
      "source": "/feed/:vertical.xml",
      "destination": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/rss-feed?vertical=:vertical"
    },
    {
      "source": "/feed/:vertical.json",
      "destination": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/json-feed?vertical=:vertical"
    },
    {
      "source": "/share/article/:postId",
      "destination": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/og-meta?postId=:postId"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
