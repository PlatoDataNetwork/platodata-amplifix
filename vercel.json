{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Vary",
          "value": "Accept-Language, Cookie"
        }
      ]
    }
  ],
  "routes": [
    { 
      "src": "/robots.txt", 
      "dest": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/robots-txt"
    },
    {
      "src": "/sitemap.xsl",
      "dest": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/sitemap-xsl"
    },
    { 
      "src": "/sitemap.xml", 
      "dest": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/sitemap?path=sitemap.xml"
    },
    { 
      "src": "/page-sitemap.xml", 
      "dest": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/sitemap?path=page-sitemap.xml"
    },
    { 
      "src": "/vertical-sitemap.xml", 
      "dest": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/sitemap?path=vertical-sitemap.xml"
    },
    { 
      "src": "/post-sitemap(\\d+).xml", 
      "dest": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/sitemap?path=post-sitemap$1.xml"
    },
    {
      "src": "/feed.xml",
      "dest": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/rss-feed"
    },
    {
      "src": "/feed.json",
      "dest": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/json-feed"
    },
    {
      "src": "/feed/([^/]+).xml",
      "dest": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/rss-feed?vertical=$1"
    },
    {
      "src": "/feed/([^/]+).json",
      "dest": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/json-feed?vertical=$1"
    },
    {
      "src": "/share/article/(\\d+)",
      "dest": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/og-meta?postId=$1"
    },
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
