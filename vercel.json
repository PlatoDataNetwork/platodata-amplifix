    },
    {
      "source": "/feed/:vertical.xml",
      "destination": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/rss-feed?vertical=:vertical"
    },
    {
      "source": "/feed/:vertical.json",
      "destination": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/json-feed?vertical=:vertical"
    },
    {
      "source": "/share/article/:postId",
      "destination": "https://tmmerifhwscgicmncndl.supabase.co/functions/v1/og-meta?postId=:postId"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
